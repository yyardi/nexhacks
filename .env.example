# Arden AI Mental Health Companion - Environment Configuration

# ============================================================================
# SUPABASE CONFIGURATION (Required)
# ============================================================================
# Get these from your Supabase project settings:
# https://app.supabase.com/project/YOUR_PROJECT/settings/api

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here


# ============================================================================
# GEMINI API (Required for Edge Functions & Sentiment Analysis)
# ============================================================================
# Get your API key from: https://aistudio.google.com/app/apikey
# Used by Supabase Edge Functions for AI analysis and sentiment analysis
# Per Arden Spec: Gemini is used for transcript sentiment analysis (Milestone 3.5)

GEMINI_API_KEY=your-gemini-api-key-here


# ============================================================================
# LIVEKIT (Required for Real-Time AI Companion - Arden Spec)
# ============================================================================
# Get credentials from: https://cloud.livekit.io
# Required for implementing the Arden real-time mental health companion

LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_URL=wss://your-project.livekit.cloud


# ============================================================================
# OVERSHOOT REALTIMEVISION (Required for Arden Spec)
# ============================================================================
# Get API key from: https://overshoot.ai
# Required for real-time emotional and behavioral visual perception

OVERSHOOT_API_KEY=your-overshoot-api-key


# ============================================================================
# OPTIONAL CONFIGURATIONS
# ============================================================================

# Development Mode
NODE_ENV=development
