# Arden AI Mental Health Companion - Environment Configuration
#
# SECURITY NOTE: This file contains both frontend and backend configurations.
# - Frontend keys (VITE_*) are bundled into the browser JavaScript
# - Backend keys are stored in Supabase Secrets for Edge Functions

# ============================================================================
# SUPABASE CONFIGURATION (Public Keys - Safe for Frontend)
# ============================================================================
# Get these from your Supabase project settings:
# https://app.supabase.com/project/YOUR_PROJECT/settings/api

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# ============================================================================
# FRONTEND API KEYS (Required for Real-Time Companion)
# ============================================================================
# These keys are used directly in the browser for real-time features.
# Get your API key from: https://overshoot.ai

VITE_OVERSHOOT_API_KEY=your-overshoot-api-key-here

# ============================================================================
# BACKEND API KEYS (Supabase Secrets - For Edge Functions Only)
# ============================================================================
# The following API keys MUST be set as Supabase Secrets for Edge Functions:
# - GEMINI_API_KEY          (for server-side AI analysis)
# - LIVEKIT_API_KEY         (for real-time voice)
# - LIVEKIT_API_SECRET      (for real-time voice)
#
# To set Supabase secrets, run:
#   supabase secrets set GEMINI_API_KEY=your-key-here
#   supabase secrets set LIVEKIT_API_KEY=your-key-here
#   supabase secrets set LIVEKIT_API_SECRET=your-secret-here
#
# See SETUP.md for detailed instructions.
